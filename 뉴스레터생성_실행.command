#!/bin/bash
# 소재타임스 주간 뉴스레터 생성 실행 파일
# 이 파일을 더블클릭하면 뉴스레터가 자동 생성됩니다.

cd "$(dirname "$0")"

echo "=========================================="
echo "  소재타임스 주간 뉴스레터 생성"
echo "=========================================="

# API 키 설정 (여기에 실제 API 키를 입력하세요)
export ANTHROPIC_API_KEY="여기에_API키_입력"

# Python 실행
python3 뉴스레터생성.py

echo ""
echo "생성된 파일: newsletter/ 폴더를 확인하세요."
echo "브라우저로 열면 뉴스레터를 미리볼 수 있습니다."
echo ""
read -p "엔터를 누르면 창이 닫힙니다..."
